{
    "name": "src/wc-planzer-shipping",
    "type": "wordpress-plugin",
    "license": "GPL2",
    "description": "Shipping via Planzer for WooCommerce",
    "homepage": "https://webwirkung.ch",
    "authors": [
        {
            "name": "Webwirkung",
            "email": "info@webwirkung.ch",
            "homepage": "https://webwirkung.ch"
        }
    ],
    "keywords": [
        "wordpress"
    ],
    "autoload": {
        "psr-4": {
            "Planzer\\": "src/"
        },
        "files": [
            "inc/helpers.php"
        ]
    },
    "require": {
        "php": ">=8.1",
        "ext-mbstring": "*",
        "ext-ctype": "*",
        "composer/installers": "*",
        "phpseclib/phpseclib": "*",
        "mpdf/mpdf": "*"
    },
    "replace": {
        "symfony/polyfill-mbstring": "*",
        "symfony/polyfill-ctype": "*",
        "ralouphie/getallheaders": "*"
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "kylekatarnls/update-helper": true
        }
    }
}
